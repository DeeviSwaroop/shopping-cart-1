          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/cart/remove/{{productId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart", "remove", "{{productId}}"]
            }
          }
        },
        {
          "name": "3.5 Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/cart/clear",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart", "clear"]
            }
          }
        }
      ]
