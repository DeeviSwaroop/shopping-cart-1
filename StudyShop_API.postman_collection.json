        },
        {
          "name": "3.3 Update Item Quantity",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 5\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/cart/update",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart", "update"]
            }
          }
        },
        {
