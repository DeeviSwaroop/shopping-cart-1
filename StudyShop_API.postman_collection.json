    {
      "name": "2. Products",
      "item": [
        {
          "name": "2.1 Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "2.2 Filter by Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/products?category=BOOKS",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products"],
              "query": [
                { "key": "category", "value": "BOOKS" }
              ]
            }
          }
        },
        {
          "name": "2.3 Filter by Category + SubCategory",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/products?category=STATIONERY&subCategory=Pens",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products"],
              "query": [
                { "key": "category", "value": "STATIONERY" },
                { "key": "subCategory", "value": "Pens" }
              ]
            }
          }
        },
        {
          "name": "2.4 Filter by Category + ClassLevel",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/products?category=BOOKS&classLevel=Class 1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products"],
              "query": [
                { "key": "category", "value": "BOOKS" },
                { "key": "classLevel", "value": "Class 1" }
              ]
            }
          }
        },
        {
          "name": "2.5 Search Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/products?search=pencil",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products"],
              "query": [
                { "key": "search", "value": "pencil" }
              ]
            }
          }
        },
        {
          "name": "2.6 Featured Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/products/featured",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products", "featured"]
            }
          }
        },
        {
          "name": "2.7 Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/products/{{productId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "2.8 Check Product Inventory",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/products/{{productId}}/inventory",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products", "{{productId}}", "inventory"]
            }
