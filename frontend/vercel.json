{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://YOUR_RENDER_BACKEND_URL.onrender.com/api/$1" },
    { "source": "/ws/(.*)", "destination": "https://YOUR_RENDER_BACKEND_URL.onrender.com/ws/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
